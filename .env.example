# Firebase Admin SDK Configuration
# Get service account JSON from Firebase Console -> Project Settings -> Service Accounts
# Copy the entire JSON content (including braces) and paste it as a single line
# IMPORTANT: Never commit this file or share your service account credentials
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# JWT signing secret (must be >= 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Access-token lifetimes per role, in SECONDS. Optional — sensible defaults apply.
# admin defaults to 24h; user & delivery_partner default to ~3 months (90 days).
JWT_TTL_ADMIN=86400       # 24 hours
JWT_TTL_USER=7776000      # 90 days
JWT_TTL_DELIVERY=7776000  # 90 days

# Default region (ISO 3166-1 alpha-2) used to validate/normalize mobile numbers
# entered without a country code. Defaults to IN (India). Full international
# numbers in E.164 (e.g. +14155552671) are always accepted regardless.
DEFAULT_PHONE_REGION=IN

# ── Refer & Earn ─────────────────────────────────────────────────────────────
# Base URL used to build shareable referral links: <base>?ref=CODE
REFERRAL_LINK_BASE=https://appname.com/register

# ── OTP SMS auto-fill (Android SMS Retriever) ────────────────────────────────
# The app's 11-char signature hash, appended to the OTP SMS so Android can
# auto-read it. Get it by logging OtpAutofillService.appSignature() in the app.
# Leave blank in dev; auto-read simply won't trigger.
ANDROID_SMS_APP_HASH=

# ── Account Deletion ─────────────────────────────────────────────────────────
# Require identity re-verification (password/OTP) before deletion. Off by
# default — the user is already authenticated, so they can delete directly.
REQUIRE_DELETE_VERIFICATION=false
# Days personal data is retained after soft-delete before anonymisation.
ACCOUNT_DELETION_RETENTION_DAYS=30
# How often the cleanup job scans for accounts due for anonymisation (ms).
ACCOUNT_CLEANUP_INTERVAL_MS=86400000
